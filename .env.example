# ─── FOMO Sydney — API Keys ──────────────────────────────────────────────────
# Copy this file to .env and fill in the keys you have.
# The app works without any keys — sources that need keys are skipped gracefully.
# More keys = more event coverage.

# ─── REQUIRED for LLM event extraction + sentiment analysis ───────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Social signal enrichment (trending algorithm) ────────────────────────────
# These power the Spotify/Last.fm popularity signals in the trending score.
# Both are free with just an account — no billing required.

# Spotify — artist popularity score (0-100) + follower count
# Get from: https://developer.spotify.com/dashboard → Create App → copy Client ID + Secret
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm — monthly listener count (most reliable popularity proxy for music)
# Get from: https://www.last.fm/api/account/create (free, instant)
LASTFM_API_KEY=

# Reddit and Wikipedia are queried without keys (public APIs).
# Facebook, Instagram, Discord: no public search APIs are available for these platforms.

# ─── Tier 1 API sources ───────────────────────────────────────────────────────

# Eventbrite — best single source for Sydney events (thousands of events)
# Get from: https://www.eventbrite.com/platform/api → Create Private Token
EVENTBRITE_TOKEN=

# Meetup — community events, tech, social groups
# Get from: https://www.meetup.com/api/guide/ → OAuth2 App
MEETUP_KEY=

# Ticketmaster — concerts, sports, major shows
# Get from: https://developer.ticketmaster.com → My Apps → Create App (free)
TICKETMASTER_KEY=

# Songkick — live music, touring artists
# Get from: https://www.songkick.com/developer → Apply for API access
SONGKICK_KEY=

# Bandsintown — artist touring data
# Get from: https://bandsintown.com/api → Request access
BANDSINTOWN_KEY=

# Humanitix — Australian community/charity events
# Get from: https://humanitix.com/au/developer → Contact their team
HUMANITIX_KEY=

# SeatGeek — sports, entertainment aggregator
# Get from: https://seatgeek.com/api → Register
SEATGEEK_CLIENT_ID=

# Skiddle — UK-origin but covers AU festivals
# Get from: https://www.skiddle.com/api → Request key
SKIDDLE_KEY=

# Yelp — dining events, food experiences
# Get from: https://www.yelp.com/developers → Create App (free, 500 req/day)
YELP_KEY=

# Google Places — venue search, event spaces
# Get from: https://console.cloud.google.com → Enable Places API (~$5/1000 req)
GOOGLE_PLACES_KEY=

# ─── Netlify deployment (required for Netlify Blobs to work) ──────────────────
# Get NETLIFY_SITE_ID from: Netlify Dashboard → Site settings → General → Site ID
# Get NETLIFY_AUTH_TOKEN from: Netlify Dashboard → User settings → Personal access tokens
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=

# ─── Server config (local dev only) ──────────────────────────────────────────
PORT=3000

# Optional: protect the manual crawl endpoint
CRAWL_TOKEN=your-secret-token-here
